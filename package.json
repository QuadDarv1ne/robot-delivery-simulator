{
  "name": "robot-delivery-simulator",
  "version": "1.0.0",
  "description": "3D Robot Delivery Simulator with Unity WebGL, ROS/ROS2 support, and real-time sensor visualization",
  "author": "Robot Simulator Team",
  "license": "MIT",
  "private": false,
  "keywords": [
    "robot",
    "simulator",
    "delivery",
    "unity",
    "webgl",
    "ros",
    "ros2",
    "lidar",
    "navigation",
    "autonomous",
    "nextjs",
    "react",
    "three.js"
  ],
  "homepage": "https://github.com/QuadDarv1ne/robot-delivery-simulator#readme",
  "bugs": {
    "url": "https://github.com/QuadDarv1ne/robot-delivery-simulator/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QuadDarv1ne/robot-delivery-simulator.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently \"next dev -p 3000\" \"cd mini-services/robot-simulator-server && bun run index.ts\" 2>&1 | tee dev.log",
    "build": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "jest --config jest.config.ts --passWithNoTests",
    "test:watch": "jest --config jest.config.ts --watch",
    "test:e2e": "playwright test",
    "test:coverage": "jest --config jest.config.ts --coverage",
    "test:hooks": "jest --config jest.config.ts --testPathPattern=hooks --testEnvironment=jsdom",
    "test:api": "jest --config jest.config.ts --testPathPattern=api",
    "test:all": "npm run test:api && npm run test:hooks",
    "websocket": "cd mini-services/robot-simulator-server && bun run index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run websocket\"",
    "seed": "ts-node scripts/seed.ts",
    "setup": "bash scripts/setup.sh",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "docker:build": "bash scripts/docker-build.sh",
    "docker:run": "docker-compose up -d",
    "docker:dev": "docker-compose --profile dev up",
    "docker:prod": "docker-compose --profile production up -d",
    "clean": "rm -rf node_modules/.cache .next dist",
    "validate": "npm run lint && npm run type-check && npm run build",
    "healthcheck": "node scripts/health-check.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.1.1",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@reactuses/core": "^6.0.5",
    "@types/leaflet": "^1.9.21",
    "@types/three": "^0.183.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.2",
    "input-otp": "^1.4.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "next-auth": "4.24.11",
    "next-themes": "^0.4.6",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-day-picker": "^9.8.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.60.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.3",
    "recharts": "^2.15.4",
    "sharp": "^0.34.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.183.2",
    "uuid": "^11.1.0",
    "vaul": "^1.1.2",
    "zod": "^4.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.4",
    "concurrently": "^8.2.2",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.3.3",
    "tailwindcss": "^4",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{js,jsx}": [
      "eslint --fix"
    ]
  }
}
