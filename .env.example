# Environment Variables Template
# Copy this file to .env and fill in your values

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL="file:./dev.db"

# ===========================================
# Authentication
# ===========================================
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# External Services (Optional)
# ===========================================
# ROS Bridge WebSocket URL (for real robot integration)
ROS_BRIDGE_URL="ws://localhost:9090"

# Simulator WebSocket Server URL
# For production, use your server URL (e.g., "wss://simulator.yourdomain.com")
NEXT_PUBLIC_SIMULATOR_URL=""

# Unity WebGL build URL
UNITY_WEBGL_URL="http://localhost:8080"

# ===========================================
# Email Configuration (Password Reset)
# ===========================================
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@example.com"
# SMTP_PASS="your-password"
# SMTP_FROM="noreply@robotsimulator.dev"

# ===========================================
# OAuth Providers (Optional)
# ===========================================
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ===========================================
# Analytics & Monitoring (Optional)
# ===========================================
# NEXT_PUBLIC_ANALYTICS_ID=""
# SENTRY_DSN=""

# ===========================================
# Feature Flags
# ===========================================
NEXT_PUBLIC_ENABLE_3D_LIDAR="true"
NEXT_PUBLIC_ENABLE_MAP="true"
NEXT_PUBLIC_ENABLE_ANALYTICS="true"
